{
	"compilerOptions": {
		"target": "es2021",
		"module": "commonjs",
		"outDir": "./dist",
		"rootDir": "./src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"allowSyntheticDefaultImports": true,
		"noImplicitAny": true,
		"resolveJsonModule": true,
		"moduleResolution": "node",
		"sourceMap": true
	},
	"include": ["src/**/*.ts", "tests/**/*.ts", "src/types"]
}
