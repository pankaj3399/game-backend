{
  "compilerOptions": {
    "target": "es2021",
    "module": "Node16",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitAny": true,
    "resolveJsonModule": true,
    "moduleResolution": "node16",
    "sourceMap": true
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "src/types"]
}
