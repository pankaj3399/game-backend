# Server
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/game
MONGODB_DB_NAME=game

# Optional dedicated secret for OAuth state signing. Falls back to JWT_SECRET when omitted.
SESSION_SECRET=your-secure-random-secret-at-least-32-chars

# Frontend URL - where to redirect after OAuth (dev: http://localhost:5173, prod: https://yourdomain.com)
REQUEST_ORIGIN=http://localhost:5173

# CORS - allowed origin for API requests (usually same as REQUEST_ORIGIN)
CORS_ORIGIN=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match route - use /api/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# JWT (required for pending signup token - used in OAuth complete-signup flow)
JWT_SECRET=your-secure-jwt-secret-at-least-32-chars

# UploadThing
UPLOADTHING_TOKEN=your-uploadthing-token
# Optional override for UploadThing callback target (recommended when behind proxy)
# Example: http://localhost:4000/api/uploadthing
UPLOADTHING_CALLBACK_URL=
# Optional: force UploadThing dev mode stream forwarding (true/false)
UPLOADTHING_IS_DEV=true

# Apple OAuth
APPLE_CLIENT_ID=com.example.myapp.signin
APPLE_TEAM_ID=K7H9M2P4Q1R
APPLE_KEY_ID=W3X5Y8Z2A6B
# Apple private key: either the raw .p8 body (recommended) or a full PEM string.
# Raw body: APPLE_PRIVATE_KEY=MIGHAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBG0wawIBAQQg...
# Full PEM: APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGHAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBG0wawIBAQQg...\n-----END PRIVATE KEY-----"
APPLE_PRIVATE_KEY=REPLACE_WITH_YOUR_APPLE_PRIVATE_KEY_BODY
# Must match route - use /api/auth/apple/callback
APPLE_CALLBACK_URL=http://localhost:3000/api/auth/apple/callback
