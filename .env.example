# Server
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/game
MONGODB_DB_NAME=game

# Session (required for cookie-based auth)
SESSION_SECRET=your-secure-random-secret-at-least-32-chars

# Frontend URL - where to redirect after OAuth (dev: http://localhost:5173, prod: https://yourdomain.com)
REQUEST_ORIGIN=http://localhost:5173

# CORS - allowed origin for API requests (usually same as REQUEST_ORIGIN)
CORS_ORIGIN=http://localhost:5173

# Cookie sameSite: 'lax' (default, same-site), 'none' (cross-domain, requires HTTPS)
COOKIE_SAME_SITE=lax

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match route - use /api/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# JWT (required for pending signup token - used in OAuth complete-signup flow)
JWT_SECRET=your-secure-jwt-secret-at-least-32-chars

# Apple OAuth
APPLE_CLIENT_ID=com.example.myapp.signin
APPLE_TEAM_ID=K7H9M2P4Q1R
APPLE_KEY_ID=W3X5Y8Z2A6B
# Apple private key: full PEM string (with -----BEGIN/END-----) or raw key content.
# Full PEM: APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGTAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBHkwdwIBAQQg...\n-----END PRIVATE KEY-----"
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGTAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBHkwdwIBAQQgREPLACE_WITH_YOUR_APPLE_PRIVATE_KEY\n-----END PRIVATE KEY-----"
# Must match route - use /api/auth/apple/callback
APPLE_CALLBACK_URL=http://localhost:3000/api/auth/apple/callback
